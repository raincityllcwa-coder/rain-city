---
import imgAboutUsImage2 from "@/assets/5b0e63419375cdde3628b20312ffa5c436161724.webp";
import imgAboutUsImage3 from "@/assets/e5d831ab1e3b9339b9d178cf62be97ce415879aa.webp";
import imgPlayIcon from "@/assets/7cd184714e63d3e219a376ebd63d6f5096b78d98.webp";
---

<section id="about" class="w-full py-12 md:py-16 lg:py-20 bg-[#f7f6f1] rounded-[5px]">
  <div class="max-w-[1150px] mx-auto px-4 md:px-8">
    <h2 class="font-['Lora'] font-bold text-[28px] md:text-[32px] text-black mb-8 md:mb-11">About Us</h2>
    <div class="flex flex-col gap-16 md:gap-[99px]">
      <!-- Block One -->
      <div class="flex flex-col md:flex-row gap-8 md:gap-[90px] items-center">
        <div class="w-full md:w-[518px] h-[280px] md:h-[350px] rounded-[5px] overflow-hidden shrink-0">
          <img src="https://lh3.googleusercontent.com/geougc/AF1QipOYbfMXZXKe8jbigDTHpaYOtPyna80bbeyNz6PN=h400" alt="Kitchen renovation project in Bellevue WA" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="font-['Montserrat'] font-normal text-[16px] text-black w-full md:w-[482px]">
          <p class="mb-4">Welcome to Rain City Kitchen & Bath — a trusted kitchen remodeling company based in Bellevue, WA. I'm Alex, the owner and general manager. We know how essential kitchens and bathrooms are to any home — they're spaces where you spend a lot of your time, and they deserve to be perfect. My mission is to deliver the best kitchen remodel in Bellevue and surrounding areas, with top-notch quality within an optimal timeframe.</p>
          <p>From the very first day, I aim to build a friendly and positive relationship with each customer. Whether you're searching for kitchen remodel companies near you or bathroom remodeling services, we want you to feel confident and at ease throughout the entire process. My core values include responsibility, meeting deadlines, and delivering exceptional quality in every project.</p>
        </div>
      </div>

      <!-- Block Two -->
      <div class="flex flex-col md:flex-row-reverse gap-8 md:gap-[82px] items-center">
        <div class="w-full md:w-[425px] h-[260px] md:h-[319px] rounded-[5px] overflow-hidden shrink-0">
          <img src={imgAboutUsImage2.src} alt="Licensed general contractors for kitchen renovation Bellevue" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="flex flex-col gap-8 md:gap-[48px] w-full md:w-[562px]">
          <h3 class="font-['Lora'] font-bold text-[22px] md:text-[24px] text-[#3b350e]">We are General Contractors</h3>
          <div class="font-['Montserrat'] font-normal text-[16px] text-black">
            <p class="mb-4">My team and I are experienced general contractors equipped with all the necessary licenses and documentation to undertake projects of any scale and complexity. As one of the top kitchen remodel companies in Bellevue, WA, our expertise spans the entire range of home improvement and kitchen renovation services.</p>
            <p>Our capabilities extend to complex renovation projects, including painting, flooring, tiling, and various related tasks. Whether you need a simple upgrade or a comprehensive kitchen remodel near you, we are committed to delivering high-quality workmanship and exceptional results tailored to your needs.</p>
          </div>
        </div>
      </div>

      <!-- Block Three -->
      <div class="flex flex-col md:flex-row gap-8 md:gap-[45px] items-center">
        <div class="w-full md:w-[531px] h-[300px] md:h-[398px] rounded-[5px] overflow-hidden shrink-0">
          <img src={imgAboutUsImage3.src} alt="Happy customers after bathroom remodeling in Bellevue" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="flex flex-col gap-8 md:gap-[46px] w-full md:w-[544px]">
          <h3 class="font-['Lora'] font-bold text-[22px] md:text-[24px] text-[#3b350e]">We Give Unforgettable Emotions</h3>
          <p class="font-['Montserrat'] font-normal text-[16px] text-black">I am passionate about delivering not only exceptional results but also a memorable experience. As a positive and open person, I love bringing joy and a good mood to my clients. That's why, at the end of each project, I celebrate with you by playing a special trombone tune, making your day truly unforgettable!</p>
          <button id="video-open" class="bg-white border border-[#989898] rounded-[5px] h-[55px] px-[18px] flex items-center gap-[14px] self-start hover:bg-gray-50 transition-colors">
            <img src={imgPlayIcon.src} alt="" class="size-[21px] object-cover" width="21" height="21" />
            <span class="font-['Montserrat'] font-normal text-[16px] text-black">Watch Video</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Video Dialog -->
  <dialog id="video-dialog" class="backdrop:bg-black/80 bg-transparent p-4 max-w-4xl w-full">
    <div class="relative">
      <button id="video-close" class="absolute -top-10 right-0 text-white hover:text-gray-300 text-3xl font-bold">×</button>
      <div class="aspect-video">
        <iframe id="video-iframe" class="w-full h-full rounded-lg" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
      </div>
    </div>
  </dialog>
</section>

<script>
  const dialog = document.getElementById('video-dialog') as HTMLDialogElement;
  const iframe = document.getElementById('video-iframe') as HTMLIFrameElement;
  
  document.getElementById('video-open')?.addEventListener('click', () => {
    iframe.src = 'https://www.youtube.com/embed/sptaH6Gtews?autoplay=1';
    dialog?.showModal();
  });
  
  document.getElementById('video-close')?.addEventListener('click', () => {
    dialog?.close();
    iframe.src = '';
  });
  
  dialog?.addEventListener('click', (e) => {
    if (e.target === dialog) { dialog.close(); iframe.src = ''; }
  });
</script>
