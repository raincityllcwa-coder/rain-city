---
import imgAboutUsImage2 from "@/assets/5b0e63419375cdde3628b20312ffa5c436161724.webp";
import imgAboutUsImage3 from "@/assets/e5d831ab1e3b9339b9d178cf62be97ce415879aa.webp";
import imgPlayIcon from "@/assets/7cd184714e63d3e219a376ebd63d6f5096b78d98.webp";
import imgOfficeExterior from "@/assets/office/office-exterior.webp";
import imgOfficeInterior from "@/assets/office/office-interior.webp";
import imgOfficeAlex from "@/assets/office/office-alex.webp";
import { sanityClient, urlFor } from '../lib/sanity';

let photo1 = '';
let photo2 = '';
let photo3 = '';

try {
  const settings = await sanityClient.fetch(
    `*[_type == "siteSettings"][0]{ aboutPhoto1, aboutPhoto2, aboutPhoto3 }`
  );
  if (settings?.aboutPhoto1) photo1 = urlFor(settings.aboutPhoto1).width(1036).format('webp').url();
  if (settings?.aboutPhoto2) photo2 = urlFor(settings.aboutPhoto2).width(850).format('webp').url();
  if (settings?.aboutPhoto3) photo3 = urlFor(settings.aboutPhoto3).width(1062).format('webp').url();
} catch (e) {
  console.warn('[Sanity] AboutSection fetch failed:', e);
}
---

<section id="about" class="w-full py-12 md:py-16 lg:py-20 bg-[#f7f6f1] rounded-[5px]">
  <div class="max-w-[1150px] mx-auto px-4 md:px-8">
    <h2 class="font-['Lora'] font-bold text-[28px] md:text-[32px] text-black mb-8 md:mb-11">About Us</h2>
    <div class="flex flex-col gap-16 md:gap-[99px]">
      <!-- Block One -->
      <div class="flex flex-col md:flex-row gap-8 md:gap-[90px] items-center">
        <div class="w-full md:w-[518px] h-[280px] md:h-[350px] rounded-[5px] overflow-hidden shrink-0">
          {photo1 ? (
            <img src={photo1} alt="Kitchen renovation project in Bellevue WA" class="w-full h-full object-cover" loading="lazy" />
          ) : (
            <div class="w-full h-full bg-gray-200 flex items-center justify-center text-gray-400 text-sm">Upload About Photo 1 in Sanity</div>
          )}
        </div>
        <div class="font-['Montserrat'] font-normal text-[16px] text-black w-full md:w-[482px]">
          <p class="mb-4">Welcome to Rain City Kitchen & Bath — a trusted kitchen remodeling company based in Bellevue, WA. I'm Alex, the owner and general manager. We know how essential kitchens and bathrooms are to any home — they're spaces where you spend a lot of your time, and they deserve to be perfect. My mission is to deliver the best kitchen remodel in Bellevue and surrounding areas, with top-notch quality within an optimal timeframe.</p>
          <p class="mb-6">From the very first day, I aim to build a friendly and positive relationship with each customer. Whether you're searching for kitchen remodel companies near you or bathroom remodeling services, we want you to feel confident and at ease throughout the entire process. My core values include responsibility, meeting deadlines, and delivering exceptional quality in every project.</p>
          <div class="border-t border-gray-200 pt-5 flex flex-col gap-2">
            <p class="font-['Lora'] font-bold text-[18px] text-[#3b350e]">Aleksandr Biriuk</p>
            <p class="text-[14px] text-gray-500 font-medium">Owner / General Chief Operating Officer</p>
            <a href="tel:2534668709" class="flex items-center gap-2 text-[15px] text-black hover:text-[#007ec5] transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.18 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.27a16 16 0 0 0 5.82 5.82l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              (253) 466-8709
            </a>
            <a href="mailto:bc85.llc@gmail.com" class="flex items-center gap-2 text-[15px] text-black hover:text-[#007ec5] transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              bc85.llc@gmail.com
            </a>
            <a href="mailto:raincityllcwa@gmail.com" class="flex items-center gap-2 text-[15px] text-black hover:text-[#007ec5] transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              raincityllcwa@gmail.com
            </a>
          </div>
        </div>
      </div>

      <!-- Block Two -->
      <div class="flex flex-col md:flex-row-reverse gap-8 md:gap-[82px] items-center">
        <div class="w-full md:w-[425px] h-[260px] md:h-[319px] rounded-[5px] overflow-hidden shrink-0">
          <img src={photo2 || imgAboutUsImage2.src} alt="Licensed general contractors for kitchen renovation Bellevue" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="flex flex-col gap-8 md:gap-[48px] w-full md:w-[562px]">
          <h3 class="font-['Lora'] font-bold text-[22px] md:text-[24px] text-[#3b350e]">We are General Contractors</h3>
          <div class="font-['Montserrat'] font-normal text-[16px] text-black">
            <p class="mb-4">My team and I are experienced general contractors equipped with all the necessary licenses and documentation to undertake projects of any scale and complexity. As one of the top kitchen remodel companies in Bellevue, WA, our expertise spans the entire range of home improvement and kitchen renovation services.</p>
            <p>Our capabilities extend to complex renovation projects, including painting, flooring, tiling, and various related tasks. Whether you need a simple upgrade or a comprehensive kitchen remodel near you, we are committed to delivering high-quality workmanship and exceptional results tailored to your needs.</p>
          </div>
        </div>
      </div>

      <!-- Block Three -->
      <div class="flex flex-col md:flex-row gap-8 md:gap-[45px] items-center">
        <div class="w-full md:w-[531px] h-[300px] md:h-[398px] rounded-[5px] overflow-hidden shrink-0">
          <img src={photo3 || imgAboutUsImage3.src} alt="Happy customers after bathroom remodeling in Bellevue" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="flex flex-col gap-8 md:gap-[46px] w-full md:w-[544px]">
          <h3 class="font-['Lora'] font-bold text-[22px] md:text-[24px] text-[#3b350e]">We Give Unforgettable Emotions</h3>
          <p class="font-['Montserrat'] font-normal text-[16px] text-black">I am passionate about delivering not only exceptional results but also a memorable experience. As a positive and open person, I love bringing joy and a good mood to my clients. That's why, at the end of each project, I celebrate with you by playing a special trombone tune, making your day truly unforgettable!</p>
          <button id="video-open" class="bg-white border border-[#989898] rounded-[5px] h-[55px] px-[18px] flex items-center gap-[14px] self-start hover:bg-gray-50 transition-colors">
            <img src={imgPlayIcon.src} alt="" class="size-[21px] object-cover" width="21" height="21" />
            <span class="font-['Montserrat'] font-normal text-[16px] text-black">Watch Video</span>
          </button>
        </div>
      </div>

      <!-- Block Four: Visit Our Office -->
      <div class="flex flex-col md:flex-row-reverse gap-8 md:gap-[45px] items-center">
        <div class="w-full md:w-[531px] grid grid-cols-12 grid-rows-2 gap-3 md:gap-4 h-[320px] md:h-[398px] shrink-0">
          <div class="col-span-7 row-span-2 rounded-[5px] overflow-hidden">
            <img src={imgOfficeExterior.src} alt="Rain City Kitchen & Bath office building in Downtown Bellevue WA" class="w-full h-full object-cover" loading="lazy" width="900" height="1200" />
          </div>
          <div class="col-span-5 row-span-1 rounded-[5px] overflow-hidden">
            <img src={imgOfficeInterior.src} alt="Office lounge with view of Downtown Bellevue skyline" class="w-full h-full object-cover" loading="lazy" width="900" height="1200" />
          </div>
          <div class="col-span-5 row-span-1 rounded-[5px] overflow-hidden">
            <img src={imgOfficeAlex.src} alt="Aleksandr Biriuk, owner of Rain City Kitchen & Bath, at the Bellevue office" class="w-full h-full object-cover object-left" loading="lazy" width="1200" height="900" />
          </div>
        </div>

        <div class="flex flex-col gap-6 w-full md:w-[544px]">
          <h3 class="font-['Lora'] font-bold text-[22px] md:text-[24px] text-[#3b350e]">
            Visit Our Office in the Heart of Bellevue
          </h3>
          <p class="font-['Montserrat'] font-normal text-[16px] text-black">
            Our office is conveniently located in the heart of Downtown Bellevue. We'd love to invite you over for a coffee, walk through our material samples, and discuss your project face-to-face. Whether you're just starting to plan or already have ideas in mind, stop by and let's bring your vision to life.
          </p>
          <div class="border-t border-gray-300 pt-5">
            <p class="font-['Montserrat'] font-semibold text-[15px] text-black mb-1">Rain City Kitchen &amp; Bath</p>
            <p class="font-['Montserrat'] font-normal text-[15px] text-gray-700">10900 NE 4th St, Unit 2300<br />Bellevue, WA 98004</p>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Video Dialog -->
  <dialog id="video-dialog" class="backdrop:bg-black/80 bg-transparent p-4 max-w-4xl w-full">
    <div class="relative">
      <button id="video-close" class="absolute -top-10 right-0 text-white hover:text-gray-300 text-3xl font-bold">×</button>
      <div class="aspect-video">
        <iframe id="video-iframe" class="w-full h-full rounded-lg" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
      </div>
    </div>
  </dialog>
</section>

<script>
  const dialog = document.getElementById('video-dialog') as HTMLDialogElement;
  const iframe = document.getElementById('video-iframe') as HTMLIFrameElement;
  
  document.getElementById('video-open')?.addEventListener('click', () => {
    iframe.src = 'https://www.youtube.com/embed/sptaH6Gtews?autoplay=1';
    dialog?.showModal();
  });
  
  document.getElementById('video-close')?.addEventListener('click', () => {
    dialog?.close();
    iframe.src = '';
  });
  
  dialog?.addEventListener('click', (e) => {
    if (e.target === dialog) { dialog.close(); iframe.src = ''; }
  });
</script>
