---
// Mobile-only call button (component name kept for backward compatibility)
---

<!-- Mobile: Call Button -->
<a
  id="call-btn"
  href="tel:2534668709"
  class="md:hidden fixed bottom-8 right-8 bg-[#007ec5] text-white size-14 rounded-full shadow-lg items-center justify-center transition-all duration-300 z-50 hidden"
  aria-label="Call us"
>
  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
</a>

<script>
  const callBtn = document.getElementById('call-btn');

  window.addEventListener('scroll', () => {
    if (!callBtn) return;
    const show = window.scrollY > 300;
    callBtn.style.display = show ? 'flex' : 'none';
  }, { passive: true });
</script>
