---
const features = [
  { title: "Licensed & Experienced", description: "Fully licensed general contractors with expertise in kitchen remodel and bathroom renovation projects of any scale and complexity" },
  { title: "Full-Service Solution", description: "From design to installation—we handle cabinets, countertops, painting, flooring, tiling, and more across Bellevue, Seattle, and the Eastside" },
  { title: "Quality & Deadlines", description: "Exceptional workmanship delivered on time, every time—not just promised, but proven by 114+ five-star reviews" },
  { title: "Customer-Focused", description: "Your satisfaction is our priority—building friendly relationships from day one of your kitchen or bathroom remodel" },
];
---

<section class="w-full py-12 md:py-16 lg:py-20 bg-[#f8f8f8]">
  <div class="max-w-[1150px] mx-auto px-4 md:px-8">
    <div class="mb-10 md:mb-12">
      <h2 class="font-['Lora'] font-bold text-[28px] md:text-[32px] text-black mb-8 md:mb-10">Why Choose Our Kitchen Remodeling Company</h2>
      <div class="flex flex-col md:flex-row-reverse items-center gap-4 md:gap-6">
        <div class="flex-shrink-0 md:w-[50%]">
          <img src="https://scontent-sea1-1.xx.fbcdn.net/v/t39.30808-6/470179791_567650836005115_840389285031575646_n.jpg?_nc_cat=106&ccb=1-7&_nc_sid=2a1932&_nc_ohc=ZWHobMmqhmIQ7kNvwGiuuCP&_nc_oc=AdrSPcvJyTgetEdcu_khuWJvr8OG6BPozm3LCDwOYOdQD3x-fHcW_Y67JeHWvXN3ohb5vB1HEuryfJt4liOIAMF2&_nc_zt=23&_nc_ht=scontent-sea1-1.xx&_nc_gid=VsXA9M69T98m26Dakc_7Fg&_nc_ss=7a389&oh=00_Af1-zaH6oaQxAMPCmmy8PSrMBnwqxLG1A2jhC1GNDZOj4A&oe=69D298D6" alt="Alex - Owner of Rain City Kitchen & Bath, kitchen remodeling company in Bellevue" class="w-full h-auto rounded-lg object-cover" loading="lazy" />
        </div>
        <div class="md:w-[50%] flex flex-col gap-4">
          <p class="font-['Montserrat'] text-[18px] md:text-[20px] text-black text-center md:text-left">Rain City Kitchen & Bath is led by Alex, owner and general manager, with a mission to deliver the best kitchen remodel in Bellevue, WA — with top-notch quality and optimal timeframes.</p>
          <p class="font-['Montserrat'] text-[18px] md:text-[20px] text-black text-center md:text-left">With years of experience in home remodeling, we combine exceptional craftsmanship with personalized service. Whether you need kitchen remodeling services or a complete bathroom renovation near you, we transform your space into something truly special.</p>
        </div>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {features.map((feature) => (
        <div class="bg-white rounded-[10px] p-6 md:p-8 flex flex-col items-center text-center shadow-sm">
          <div class="w-16 h-16 mb-4 flex items-center justify-center">
            <svg class="w-12 h-12 text-[#007ec5]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          </div>
          <h3 class="font-['Lora'] font-bold text-[20px] md:text-[22px] text-black mb-3">{feature.title}</h3>
          <p class="font-['Montserrat'] text-[14px] md:text-[15px] text-black leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
