---
import imgHeroBg from "@/assets/c4e93df24993f176102d516e4e5e7a4fd86822b6.webp";
---
<section class="relative w-full h-[300px] md:h-[400px] flex items-center">
  <div class="absolute inset-0">
    <img src={imgHeroBg.src} alt="" class="w-full h-full object-cover" loading="eager" />
    <div class="absolute inset-0 bg-black/60"></div>
  </div>
  <div class="relative max-w-[1150px] mx-auto px-4 md:px-8 w-full">
    <h1 class="font-['Lora'] font-bold text-[32px] md:text-[42px] text-white leading-tight">Our Services</h1>
    <p class="font-['Montserrat'] font-normal text-[16px] md:text-[18px] text-white mt-4">Professional kitchen and bathroom remodeling services</p>
  </div>
</section>
