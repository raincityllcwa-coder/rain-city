<section class="w-full py-16 md:py-20 bg-gray-50">
  <div class="max-w-[1150px] mx-auto px-4 md:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">
      <div>
        <h2 class="font-['Lora'] font-bold text-[32px] md:text-[40px] lg:text-[44px] text-black mb-4">Ready to Get Started?</h2>
        <p class="font-['Montserrat'] text-[16px] md:text-[18px] text-gray-700 mb-6">Transform your kitchen or bathroom with Rain City Kitchen & Bath.</p>
        <div class="space-y-3">
          <div class="flex items-center gap-3"><div class="w-2 h-2 bg-[#007ec5] rounded-full"></div><p class="font-['Montserrat'] text-[15px] text-gray-700">Free consultation & quote</p></div>
          <div class="flex items-center gap-3"><div class="w-2 h-2 bg-[#007ec5] rounded-full"></div><p class="font-['Montserrat'] text-[15px] text-gray-700">Expert design advice</p></div>
          <div class="flex items-center gap-3"><div class="w-2 h-2 bg-[#007ec5] rounded-full"></div><p class="font-['Montserrat'] text-[15px] text-gray-700">Professional installation</p></div>
        </div>
      </div>
      <div class="bg-[#007ec5] p-6 rounded-[5px]">
        <h3 class="font-['Lora'] font-bold text-[22px] text-white mb-3 text-center">Get Started Today</h3>
        <p class="font-['Montserrat'] text-[15px] text-white/90 mb-6 text-center">Contact us for a free consultation and quote.</p>
        <form class="space-y-4" data-form="cta">
          <input type="text" name="name" placeholder="Your Name" required class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-[5px] font-['Montserrat'] text-[15px] text-white placeholder:text-white/60 focus:outline-none focus:ring-2 focus:ring-white/50" />
          <input type="email" name="email" placeholder="Your Email" required class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-[5px] font-['Montserrat'] text-[15px] text-white placeholder:text-white/60 focus:outline-none focus:ring-2 focus:ring-white/50" />
          <input type="tel" name="phone" placeholder="(___) ___-____" required pattern="[0-9()\-\s+]{10,}" minlength="10" title="Enter a valid phone number" class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-[5px] font-['Montserrat'] text-[15px] text-white placeholder:text-white/60 focus:outline-none focus:ring-2 focus:ring-white/50" />
          <button type="submit" class="w-full px-6 py-3 bg-white text-[#007ec5] font-['Montserrat'] font-semibold text-[16px] rounded-[5px] hover:bg-gray-100 transition-colors">Request a Quote</button>
        </form>
        <div class="hidden text-center py-6" data-success="cta">
          <p class="font-['Montserrat'] text-[18px] text-white font-semibold">Thank you! We'll contact you shortly.</p>
        </div>
      </div>
    </div>
  </div>
</section>
