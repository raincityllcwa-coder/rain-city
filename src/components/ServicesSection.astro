---
import { ImageCarousel } from './ui/ImageCarousel';

// Kitchen Cabinets — 5 best photos for carousel
import imgKc01 from "@/assets/kitchen-cabinets/kc-05.webp";
import imgKc02 from "@/assets/kitchen-cabinets/kc-07.webp";
import imgKc03 from "@/assets/kitchen-cabinets/kc-06.webp";
import imgKc04 from "@/assets/kitchen-cabinets/kc-12.webp";
import imgKc05 from "@/assets/kitchen-cabinets/kc-03.webp";

// Kitchen Countertops — keep existing for now
import imgCountertop from "@/assets/45b63473772ac5eedb2419a124f3a11b4a82ba56.webp";

// Bathroom Remodel — keep existing for now
import imgBathroom from "@/assets/2221dd725ae6402fca45a45bd79869231da67ce7.webp";

const kitchenCabinetsImages = [
  imgKc01.src,
  imgKc02.src,
  imgKc03.src,
  imgKc04.src,
  imgKc05.src,
];

const kitchenCountertopsImages = [
  imgCountertop.src,
];

const bathroomRemodelImages = [
  imgBathroom.src,
];

const services = [
  { images: kitchenCabinetsImages, link: "/kitchen-cabinets", title: "Kitchen Cabinets", color: "#3b350e", bg: "#f7f6f1", text: "As a leading kitchen remodeling company in Bellevue, we specialize in both standard and custom cabinets to meet your unique needs. Our clients can choose from a variety of styles and color schemes, with Shaker and Flat door styles being the most popular options for kitchen renovation in Bellevue and Seattle.", reverse: false },
  { images: kitchenCountertopsImages, link: "/kitchen-countertops", title: "Kitchen Countertops", color: "#021b3c", bg: "#f1f3f7", text: "We offer a wide variety of countertop materials, including quartz, granite, and marble, available in different styles, colors, and thicknesses. Our kitchen remodeling services include delivery, precise fabrication, and professional installation across Bellevue, Kirkland, Redmond, and the Eastside.", reverse: true },
  { images: bathroomRemodelImages, link: "/bathroom-remodel", title: "Bathroom Remodel", color: "#3b350e", bg: "#f7f6f1", text: "Looking for bathroom remodeling services near you? Transform your bathroom with our high-quality materials, including porcelain tile, natural stone, or glass tile. We offer a wide range of styles and finishes to create the perfect look for your space.", reverse: false },
];
---

<section id="services" class="w-full py-12 md:py-16 lg:py-20">
  <div class="max-w-[1150px] mx-auto px-4 md:px-8">
    <h2 class="font-['Lora'] font-bold text-[28px] md:text-[32px] text-black mb-8 md:mb-11">Kitchen Remodeling & Bathroom Renovation Services</h2>
    <div class="flex flex-col gap-12 md:gap-[68px]">
      {services.map((s) => (
        <div class="relative">
          <div class={`flex flex-col ${s.reverse ? 'md:flex-row-reverse' : 'md:flex-row'} gap-6 md:gap-0 items-center`}>
            <ImageCarousel client:visible images={s.images} alt={s.title} link={s.link} />
            <div class={`hidden md:block absolute ${s.reverse ? 'left-0' : 'right-0'} top-[24px] w-[676px] h-[393px] rounded-[5px]`} style={`background:${s.bg}`}></div>
            <div class={`w-full md:w-[460px] ${s.reverse ? 'md:mr-[90px]' : 'md:ml-[90px]'} relative z-10 p-6 md:p-0 rounded-[5px] md:rounded-none`} style={`background:${s.bg}`}>
              <h3 class="font-['Lora'] font-bold text-[20px] md:text-[24px] mb-[22px]" style={`color:${s.color}`}>{s.title}</h3>
              <p class="font-['Montserrat'] font-normal text-[16px] text-black">{s.text}</p>
              <a href={s.link} class="inline-block mt-4 py-3 font-['Montserrat'] font-semibold text-[15px] text-[#007ec5] hover:underline">Learn More →</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
