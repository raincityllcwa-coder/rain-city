---
import imgTelephoneIcon from "@/assets/a7886c55528f6e197789a4b7d647dd63cdc250d2.webp";
---

<!-- Top Navigation - Desktop Only -->
<div class="bg-[#f3f3f3] w-full hidden md:block">
  <div class="max-w-[1150px] mx-auto px-4 md:px-8 h-[50px] flex items-center justify-end">
    <div class="flex items-center gap-[15px]">
      <img src={imgTelephoneIcon.src} alt="Call us" class="size-[22px] object-cover" width="22" height="22" />
      <p class="font-['Montserrat'] font-medium text-[14px] md:text-[16px] text-black whitespace-nowrap">Call Us: (253) 466-8709</p>
    </div>
  </div>
</div>

<!-- Main Header -->
<div class="bg-white w-full z-50">
  <div class="max-w-[1150px] mx-auto px-4 md:px-8 py-3 md:py-[25px] md:pb-[28px]">
    <div class="flex items-center justify-between">
      <a href="/" class="flex flex-col gap-[2px] md:gap-[7px] shrink-0">
        <p class="font-['Lora'] font-bold text-[24px] md:text-[30px] text-[#051e2a] uppercase leading-[30px] md:leading-tight whitespace-nowrap">Rain City</p>
        <div class="h-[1px] bg-[#051e2a] opacity-40 min-w-[120px] md:w-full"></div>
        <p class="font-['Montserrat'] font-normal text-[16px] md:text-[20px] text-[#051e2a] leading-[20px] md:leading-tight whitespace-nowrap">Kitchen & Bath</p>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex gap-[29px] items-center text-[18px] text-black">
        <a href="/" class="font-['Montserrat'] font-medium hover:text-[#007ec5] transition-colors">Home</a>
        <a href="/our-services" class="font-['Montserrat'] font-normal hover:text-[#007ec5] transition-colors">Our Services</a>
        <a href="/about" class="font-['Montserrat'] font-normal hover:text-[#007ec5] transition-colors">About Us</a>
        <a href="/contact" class="font-['Montserrat'] font-normal hover:text-[#007ec5] transition-colors">Contact</a>
      </nav>

      <!-- Mobile Phone & Menu -->
      <div class="lg:hidden flex items-center gap-3">
        <a href="tel:2534668709" class="flex items-center">
          <img src={imgTelephoneIcon.src} alt="Call us" class="w-[22px] h-[22px] object-cover" width="22" height="22" />
        </a>
        <button id="burger-btn" class="flex flex-col gap-[5px] w-6 h-6 justify-center items-center" aria-label="Toggle menu">
          <span class="burger-line w-6 h-[2px] bg-black transition-all"></span>
          <span class="burger-line w-6 h-[2px] bg-black transition-opacity"></span>
          <span class="burger-line w-6 h-[2px] bg-black transition-all"></span>
        </button>
      </div>
    </div>

    <!-- Mobile Navigation -->
    <nav id="mobile-nav" class="lg:hidden mt-6 flex-col gap-4 pb-4 border-t pt-4 hidden">
      <a href="/" class="font-['Montserrat'] font-medium text-[16px] text-black hover:text-[#007ec5] transition-colors">Home</a>
      <a href="/our-services" class="font-['Montserrat'] font-normal text-[16px] text-black hover:text-[#007ec5] transition-colors">Our Services</a>
      <a href="/about" class="font-['Montserrat'] font-normal text-[16px] text-black hover:text-[#007ec5] transition-colors">About Us</a>
      <a href="/contact" class="font-['Montserrat'] font-normal text-[16px] text-black hover:text-[#007ec5] transition-colors">Contact</a>
    </nav>
  </div>
</div>

<script>
  const btn = document.getElementById('burger-btn');
  const nav = document.getElementById('mobile-nav');
  const lines = document.querySelectorAll('.burger-line');

  btn?.addEventListener('click', () => {
    const open = nav?.classList.toggle('hidden') === false;
    nav?.classList.toggle('flex', open);
    if (lines[0]) lines[0].classList.toggle('rotate-45', open);
    if (lines[0]) lines[0].classList.toggle('translate-y-[7px]', open);
    if (lines[1]) lines[1].classList.toggle('opacity-0', open);
    if (lines[2]) lines[2].classList.toggle('-rotate-45', open);
    if (lines[2]) lines[2].classList.toggle('-translate-y-[7px]', open);
  });
</script>
