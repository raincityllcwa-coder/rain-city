---
import Layout from '../layouts/Layout.astro';
import ServiceLandingHero from '../components/services/ServiceLandingHero.astro';
import { ServiceContentSection } from '../components/services/ServiceContentSection';
import { ReviewsGridSection } from '../components/services/ReviewsGridSection';
import { ProjectsSection } from '../components/ProjectsSection';
import WhyChooseUsSection from '../components/WhyChooseUsSection.astro';
import OurProcessSection from '../components/OurProcessSection.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import imgServiceImage from "../assets/2221dd725ae6402fca45a45bd79869231da67ce7.webp";

// ── Sanity ──
import { getReviews, getProjects } from '../lib/queries';
import { transformReviews, transformProjects } from '../lib/transforms';

let reviewsData: any[] = [];
let projectsData: any[] = [];

try {
  const [r, p] = await Promise.all([
    getReviews('bathroom-remodel'),
    getProjects('bathroom-remodel'),
  ]);
  if (r?.length) reviewsData = transformReviews(r);
  if (p?.length) projectsData = transformProjects(p);
} catch (e) {
  console.warn('[Sanity] bathroom-remodel fetch failed:', e);
}

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Bathroom Remodeling",
  "description": "Complete bathroom remodeling with porcelain tile, natural stone, and glass tile in Bellevue, Seattle and surrounding areas.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Rain City Kitchen & Bath",
    "telephone": "(253) 466-8709",
    "address": { "@type": "PostalAddress", "addressLocality": "Bellevue", "addressRegion": "WA" }
  },
  "areaServed": "Seattle metropolitan area",
  "serviceType": "Bathroom Remodeling"
};
---

<Layout
  title="Bathroom Remodel - Expert Renovation | Rain City Kitchen & Bath"
  description="Complete bathroom remodeling in Bellevue & Seattle. Porcelain, natural stone, glass tile. Spa-like design. Free estimate. 5-star rated."
  jsonLd={jsonLd}
>
  <ServiceLandingHero backgroundImage={imgServiceImage.src} title="Complete Bathroom Remodeling" subtitle="Transform your bathroom into a luxurious retreat with our comprehensive remodeling services." />
  <ServiceContentSection client:visible title="Complete Bathroom Transformation" paragraphs={["Transform your bathroom with our high-quality materials, including porcelain tile, natural stone, or glass tile. We offer a wide range of styles and finishes to create the perfect look for your space.","Whether you're looking for a spa-like master bathroom or a functional family bath, our team creates spaces that combine beauty, durability, and practicality."]} />
  <ReviewsGridSection client:visible reviews={reviewsData.length > 0 ? reviewsData : undefined} />
  <ProjectsSection client:visible projects={projectsData.length > 0 ? projectsData : undefined} />
  <WhyChooseUsSection />
  <OurProcessSection />
  <ScrollToTop />
</Layout>
