---
import Layout from '../layouts/Layout.astro';
import ServiceLandingHero from '../components/services/ServiceLandingHero.astro';
import { ServiceContentSection } from '../components/services/ServiceContentSection';
import { ReviewsGridSection } from '../components/services/ReviewsGridSection';
import { ProjectsSection } from '../components/ProjectsSection';
import WhyChooseUsSection from '../components/WhyChooseUsSection.astro';
import OurProcessSection from '../components/OurProcessSection.astro';
import FAQSection from '../components/FAQSection.astro';
import ServiceAreaSection from '../components/ServiceAreaSection.astro';
import WideLeadFormSection from '../components/WideLeadFormSection.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import imgServiceImage from "../assets/45b63473772ac5eedb2419a124f3a11b4a82ba56.webp";

// ── Sanity ──
import { getReviews, getProjects, getFAQs } from '../lib/queries';
import { transformReviews, transformProjects } from '../lib/transforms';

let reviewsData: any[] = [];
let projectsData: any[] = [];
let faqsData: any[] = [];

try {
  const [r, p, f] = await Promise.all([
    getReviews('kitchen-countertops'),
    getProjects('kitchen-countertops'),
    getFAQs('kitchen-countertops'),
  ]);
  if (r?.length) reviewsData = transformReviews(r);
  if (p?.length) projectsData = transformProjects(p);
  if (f?.length) faqsData = f;
} catch (e) {
  console.warn('[Sanity] kitchen-countertops fetch failed:', e);
}

const faqItems = faqsData.length > 0 ? faqsData : [
  { question: "What is the best countertop material for kitchens?", answer: "Quartz is our most popular recommendation due to its durability, low maintenance, and wide variety of colors and patterns. Granite and quartzite are excellent natural stone alternatives, while marble offers timeless elegance." },
  { question: "How long does a kitchen remodel take?", answer: "A typical kitchen remodel takes 6-12 weeks, depending on the scope of work. Minor updates like cabinet refacing or countertop replacement can be completed in 2-4 weeks, while full-scale renovations with layout changes may take 3-4 months." },
  { question: "Do I need permits for a kitchen remodel?", answer: "Yes, most kitchen remodels require permits, especially if you're making structural changes, moving plumbing or electrical, or changing the layout. We handle all permit applications and ensure your project meets local building codes." },
  { question: "Do you offer financing options for kitchen remodeling?", answer: "Yes, we partner with trusted financing providers to offer flexible payment plans. We can help you find options that fit your budget, including low-interest loans and special promotional financing." },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Kitchen Countertops Installation",
    "description": "Premium quartz, granite, and marble countertop fabrication and installation in Bellevue, Seattle and surrounding areas.",
    "provider": {
      "@type": "LocalBusiness",
      "name": "Rain City Kitchen & Bath",
      "telephone": "(253) 466-8709",
      "address": { "@type": "PostalAddress", "addressLocality": "Bellevue", "addressRegion": "WA" }
    },
    "areaServed": "Seattle metropolitan area",
    "serviceType": "Countertop Installation"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": { "@type": "Answer", "text": faq.answer }
    }))
  }
];
---

<Layout
  title="Kitchen Countertops - Quartz, Granite & Marble | Rain City Kitchen & Bath"
  description="Premium quartz, granite and marble countertop installation in Bellevue & Seattle. Expert fabrication, delivery and professional installation. Free estimate."
  jsonLd={jsonLd}
>
  <ServiceLandingHero backgroundImage={imgServiceImage.src} title="Premium Kitchen Countertops" subtitle="Enhance your kitchen with premium countertops featuring quartz, granite, and marble in a variety of styles and finishes." />
  <ServiceContentSection client:visible title="Premium Countertop Materials" paragraphs={["We offer a wide variety of countertop materials, including quartz, granite, and marble, available in different styles, colors, and thicknesses to suit your needs.","Each countertop material offers unique benefits, and our expert team will help you choose the perfect option for your kitchen based on your lifestyle, design preferences, and budget."]} />
  <ReviewsGridSection client:visible reviews={reviewsData.length > 0 ? reviewsData : undefined} />
  <ProjectsSection client:visible projects={projectsData.length > 0 ? projectsData : undefined} />
  <WhyChooseUsSection />
  <OurProcessSection />
  <FAQSection faqs={faqsData.length > 0 ? faqsData : undefined} />
  <ServiceAreaSection />
  <WideLeadFormSection />
  <ScrollToTop />
</Layout>
