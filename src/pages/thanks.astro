---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thank You - Rain City Kitchen & Bath">
  <section class="w-full min-h-[60vh] flex items-center justify-center bg-[#f7f6f1]">
    <div class="max-w-[600px] mx-auto px-4 text-center">
      <div class="w-20 h-20 bg-[#007ec5] rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h1 class="font-['Lora'] font-bold text-[32px] md:text-[42px] text-black mb-4">Thank You!</h1>
      <p class="font-['Montserrat'] text-[18px] md:text-[20px] text-gray-700 mb-8">
        We've received your request and will contact you shortly with a free quote.
      </p>
      <a href="/" class="inline-block bg-[#007ec5] text-white font-['Montserrat'] font-bold text-[16px] px-8 py-4 rounded-[5px] hover:bg-[#006ba8] transition-colors">
        Back to Home
      </a>
    </div>
  </section>
</Layout>
